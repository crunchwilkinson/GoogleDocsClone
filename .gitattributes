# Normalize line endings for all text files to LF
* text=auto

# C# files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.slnx text eol=lf

# ASP.NET Core
*.cshtml text eol=lf
*.aspx text eol=lf
*.asax text eol=lf
*.ashx text eol=lf

# Configuration files
*.json text eol=lf
*.config text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.js text eol=lf
*.ts text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.dll binary
*.exe binary
*.so binary
*.dylib binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
*.db binary
*.sqlite binary

# Merge strategies for specific files
*.csproj merge=union
*.sln merge=union