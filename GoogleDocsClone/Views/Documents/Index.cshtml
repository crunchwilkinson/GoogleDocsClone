@model IEnumerable<GoogleDocsClone.Models.Document>

@{
    ViewData["Title"] = "My Documents";
}

<!-- Hero Section -->
<div class="docs-content-area">
    <div class="docs-hero mb-5">
        <div class="hero-content">
            <div class="hero-text">
                <span class="hero-badge">Document Platform</span>
                <h1 class="docs-title mb-2">My Documents</h1>
                <p class="docs-subtitle">Create, edit, and collaborate on documents in real-time.<br>Secure, private, and always up-to-date.</p>
                <p class="docs-subtitle docs-subtitle-secondary">Powered by TinyMCE.</p>
            </div>
            <div class="hero-icon">
                <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                </svg>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <!-- Create New Document Section -->
    <section class="create-section">
        <div class="section-header">
            <h3 class="section-title">Start a new document</h3>
            <p class="section-subtitle">Create a fresh, blank document to begin writing</p>
        </div>
        <div class="home-features-grid">
            <a asp-action="Create" class="home-feature-card doc-card-horizontal doc-card-link create-card-blue">
                <div class="home-feature-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="12" y1="11" x2="12" y2="17"></line>
                        <line x1="9" y1="14" x2="15" y2="14"></line>
                    </svg>
                </div>
                <div>
                    <h4 class="home-feature-title">Blank document</h4>
                    <p class="home-feature-desc">Start from scratch</p>
                </div>
            </a>
            <div class="home-feature-card doc-card-horizontal">
                <div class="home-feature-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
                    </svg>
                </div>
                <div>
                    <h4 class="home-feature-title">Rich Text Editing</h4>
                    <p class="home-feature-desc">Format with bold, italic, lists, tables, and more</p>
                </div>
            </div>
            <div class="home-feature-card doc-card-horizontal">
                <div class="home-feature-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                </div>
                <div>
                    <h4 class="home-feature-title">Secure & Private</h4>
                    <p class="home-feature-desc">Your documents are tied to your account only</p>
                </div>
            </div>
            <div class="home-feature-card doc-card-horizontal">
                <div class="home-feature-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                    </svg>
                </div>
                <div>
                    <h4 class="home-feature-title">Blazing Fast</h4>
                    <p class="home-feature-desc">Built on .NET Core for a snappy experience</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Documents List -->
    @if (Model.Any())
    {
        <section class="recent-section mt-5">
            <div class="section-header">
                <h3 class="section-title">Recent documents</h3>
                <p class="section-subtitle">Your recently edited files</p>
            </div>
            <div class="home-features-grid">
                @foreach (var item in Model)
                {
                    <a asp-action="Edit" asp-route-id="@item.Id" class="home-feature-card doc-card-link doc-card-horizontal">
                        <div class="home-feature-icon">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path>
                                <polyline points="14 2 14 8 20 8"></polyline>
                                <line x1="9" y1="13" x2="15" y2="13"></line>
                                <line x1="9" y1="17" x2="13" y2="17"></line>
                            </svg>
                        </div>
                        <div>
                            <h4 class="home-feature-title">@item.Title</h4>
                            <p class="home-feature-desc">Modified @item.UpdatedAt.ToString("MM/dd/yy HH:mm")</p>
                        </div>
                    </a>
                }
            </div>
        </section>
    }
    else
    {
        <section class="recent-section mt-5">
            <div class="section-header">
                <h3 class="section-title">Recent documents</h3>
                <p class="section-subtitle">Your recently edited files</p>
            </div>
            <div class="home-features-grid">
                <div class="home-feature-card doc-card-horizontal" style="opacity: 0.7;">
                    <div class="home-feature-icon">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path>
                            <polyline points="14 2 14 8 20 8"></polyline>
                        </svg>
                    </div>
                    <div>
                        <h4 class="home-feature-title">No documents yet</h4>
                        <p class="home-feature-desc">Start creating documents by clicking the button above</p>
                    </div>
                </div>
            </div>
        </section>
    }
</div>