@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Forgot password confirmation";
}

<div class="identity-shell">
    <div class="identity-card" style="text-align: center;">
        <h1 class="identity-title">Check your email</h1>
        <p class="identity-subtitle">We've sent you a link to reset your password. Please check your inbox.</p>
        <div class="identity-links" style="margin-top: 1.5rem;">
            <a asp-page="./Login">Back to login</a>
        </div>
    </div>
</div>
